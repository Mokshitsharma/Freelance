rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid (string)
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - phone: string (required) - Verified phone number
    //   - name: string (optional) - Full name
    //   - age: number (optional) - Age
    //   - profession: string (optional) - Profession
    //   - native_place: string (optional) - Native place
    //   - current_city: string (optional) - Current city
    //   - role: string (required) - 'member' or 'admin'
    //   - created_at: string (required) - ISO timestamp
    //
    // Collection: whatsapp_verifications
    // Document ID: verificationId (string)
    // Fields:
    //   - code: string - Verification code
    //   - status: string - 'pending' or 'verified'
    //   - phone: string - Verified phone number
    //   - uid: string - User ID
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "mokshitsharmalaptop@gmail.com" ||
         (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'active'));
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "mokshitsharmalaptop@gmail.com";
    }

    // Admins Collection
    match /admins/{adminId} {
      // Super admin can read all. Users can read their own request.
      allow read: if isSuperAdmin() || isOwner(adminId);
      
      // Anyone can request admin access
      allow create: if isAuthenticated() && isOwner(adminId) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.role == 'admin' &&
        request.resource.data.email == request.auth.token.email;
        
      // Only super admin can approve/reject
      allow update: if isSuperAdmin() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
        
      allow delete: if isSuperAdmin();
    }

    // Users Collection
    match /users/{userId} {
      // Allow reading approved profiles publicly
      allow read: if isAdmin() || (resource.data.status == 'approved');
      
      // Allow public creation (registration)
      allow create: if request.resource.data.status == 'pending' &&
        request.resource.data.role == 'member' &&
        request.resource.data.phone.matches('^[0-9]{10}$');
        
      // Only admin can update or delete
      allow update, delete: if isAdmin();
    }

    // Events Collection
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Event Registrations
    match /event_registrations/{regId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.user_id);
      allow update, delete: if isAdmin();
    }

    // Parichay Profiles
    match /parichay_profiles/{profileId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.user_id);
      allow update: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow delete: if isAdmin();
    }

    // Donations
    match /donations/{donationId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.user_id) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.user_id);
      allow update, delete: if isAdmin();
    }

    // Books
    match /books/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Helplines
    match /helplines/{helplineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Gallery
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leadership Messages
    match /leadership_messages/{messageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // WhatsApp Verifications (Internal use, but rules needed)
    match /whatsapp_verifications/{id} {
      // Only admin (backend) should really touch this, but we allow read for polling if needed
      // Actually, polling is done via API, so we can deny all here for safety
      allow read, write: if false;
    }
    
    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
